# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/

# ─── Expo ───────────────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts
.expo-export-check/

# ─── Native build outputs ───────────────────────────────────────────────────
/ios/
/android/
.kotlin/
*.orig.*

# ─── Certificates & Secrets ─────────────────────────────────────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ─── Environment variables ───────────────────────────────────────────────────
.env
.env.local
.env*.local
.env.production

# ─── Metro bundler ───────────────────────────────────────────────────────────
.metro-health-check*

# ─── Debug logs ──────────────────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── EAS ─────────────────────────────────────────────────────────────────────
.easignore

# ─── Prompt/AI development helpers (not for production repo) ─────────────────
prompt_material/
prompts/

# ─── Agent/AI tool config (keep local only) ──────────────────────────────────
.agents/
.claude/

# ─── Misc ────────────────────────────────────────────────────────────────────
example
skills-lock.json
